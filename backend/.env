# Настройка развертывания сервера

# Для разработки использовать localhost.
# HOST=localhost
HOST=0.0.0.0
# Перед запуском необходимо проверить разрешенность порта в firewall
PORT=5001
# Возможные варианты переменной (development, production)
NODE_ENV=development

# Настройки БД SQLite3
DB_PATH=database

# Настройка телеграмм бота
TELEGRAM_BOT_TOKEN=

# Настройка разрешенных адресов доступа к backend
CORS_ORIGIN=

LOG_LEVEL=info
LOG_ERROR_FILE=logs/error.log
LOG_COMBINED_FILE=logs/combined.log